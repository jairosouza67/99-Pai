{
  "version": 2,
  "installCommand": "cd ../.. && npm ci",
  "builds": [
    {
      "src": "api/[...all].ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/[...all].ts"
    }
  ],
  "crons": [
    {
      "path": "/api/health",
      "schedule": "0 3 */5 * *"
    }
  ]
}