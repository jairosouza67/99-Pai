# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>  # Usado apenas por Edge Functions — NUNCA expor no mobile

# Mobile — Supabase (public keys, safe for client)
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# TTS (Voice) — Fallback: OpenRouter → OpenAI Direto → Google Cloud
TTS_BUCKET=tts-cache

# 1) OpenRouter (provedor TTS primario)
OPENROUTER_API_KEY=<openrouter-api-key>
OPENROUTER_TTS_MODEL=openai/gpt-4o-mini-tts-2025-12-15
OPENROUTER_TTS_VOICE=coral
OPENROUTER_TTS_SPEED=0.95
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 2) OpenAI Direto (fallback secundario)
OPENAI_API_KEY=<openai-api-key>
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_SPEED=0.95

# 3) Google Cloud TTS (fallback terciario)
# Opção 1: caminho para arquivo de credenciais JSON
# GOOGLE_APPLICATION_CREDENTIALS=C:/keys/google-tts-service-account.json
# Opção 2: conteúdo JSON inteiro em uma string
# GOOGLE_TTS_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_TTS_LANGUAGE_CODE=pt-BR
GOOGLE_TTS_VOICE_NAME=pt-BR-Chirp3-HD-Leda
GOOGLE_TTS_SPEAKING_RATE=0.92
GOOGLE_TTS_PITCH=0

# Edge Functions Secrets (configure via `supabase secrets set`)
# OPENROUTER_API_KEY=...
# OPENAI_API_KEY=...
# GOOGLE_TTS_CREDENTIALS_JSON=...
# LINK_CODE_TTL_HOURS=24
