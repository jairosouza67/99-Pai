# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>  # Backend apenas — NUNCA expor no mobile

# Auth (JWT interno do NestJS — mantém por enquanto)
